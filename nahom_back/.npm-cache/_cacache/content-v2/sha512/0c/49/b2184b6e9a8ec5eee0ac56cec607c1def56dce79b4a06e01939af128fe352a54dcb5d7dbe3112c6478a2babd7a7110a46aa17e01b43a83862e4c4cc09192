(['bamse', 'beans']),\n    dogs: {\n      schnauzers: Promise.resolve({\n        kokos: {\n          isSchnauzer: true,\n          isCute: Promite.resolve(true),\n        },\n      }),\n      mixed: Promise.resolve('katla'),\n    },\n  })\n)\n```\n\n## License\n\nMIT-licensed. See LICENSE.\n","maintainers":[{"name":"rexxars","email":"espen@hovlandsdal.com"}],"time":{"modified":"2022-06-24T18:59:19.857Z","created":"2016-01-20T12:59:59.228Z","1.0.0":"2016-01-20T12:59:59.228Z","2.0.0":"2022-02-08T02:31:11.343Z","2.0.1":"2022-02-09T00:09:36.784Z","2.0.2":"2022-03-03T05:51:38.201Z"},"homepage":"https://github.com/rexxars/promise-props-recursive#readme","keywords":["promise","object","recursive"],"repository":{"type":"git","url":"git+https://github.com/rexxars/promise-props-recursive.git"},"author":{"name":"Espen Hovlandsdal","email":"espen@hovlandsdal.com"},"bugs":{"url":"https://github.com/rexxars/promise-props-recursive/issues"},"license":"MIT","readmeFilename":"README.md"}